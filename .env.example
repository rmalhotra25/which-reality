# Claude / Anthropic API key — required for AI analysis
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PostgreSQL — set this for persistent storage on Render / production
# Get a free database at https://neon.tech (free tier, no credit card needed)
# Format: postgresql://user:password@host/dbname?sslmode=require
# DATABASE_URL=postgresql://...

# SQLite fallback — used only when DATABASE_URL is not set (local dev)
DB_PATH=../data/trading.db

# Server port
BACKEND_PORT=8000
